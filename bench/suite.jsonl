// score.type: numeric | keywords(all) | any | regex | (omit = judge-only)
{"id": "tutor_candle", "category": "tutor", "prompt": "In two or three sentences, explain what the wick of a candlestick represents.", "score": {"type": "any", "any": ["high", "low", "highest", "lowest"]}}
