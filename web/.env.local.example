# Copy to .env.local. The web app reads these at build/runtime.
NEXT_PUBLIC_MARKET_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Tutor: self-hosted, OpenAI-compatible model (no external API) ---
# Point at your LAN Nemotron. These are server-side only (never sent to browser).
# Leave blank to run the tutor in retrieval-only mode (matched lesson text, no LLM).
TUTOR_LLM_URL=http://192.168.110.145:8000/v1
TUTOR_MODEL=
TUTOR_API_KEY=
