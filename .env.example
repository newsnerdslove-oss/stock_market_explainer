# Copy this file to ".env" and fill in. NEVER commit the real .env.

# --- Alpaca (free paper-trading account) ---
# Create at https://alpaca.markets -> Paper account -> generate keys.
# Leave blank to run the market-service in mock mode.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# --- Supabase (free Postgres + Auth) ---
# Create at https://supabase.com -> new project -> Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional data fallback ---
FINNHUB_API_KEY=

# --- Service wiring ---
MARKET_SERVICE_URL=http://localhost:8000

# --- Tutor: self-hosted, OpenAI-compatible model (no external API) ---
# Points the in-app tutor at your LAN Nemotron. Server-side only.
# Leave blank for retrieval-only mode (answers from lesson text, no LLM).
# See docs/TUTOR.md.
TUTOR_LLM_URL=http://192.168.110.145:8082/v1
TUTOR_MODEL=
TUTOR_API_KEY=
